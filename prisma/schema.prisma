model ReportPromptTemplate {
  id         String   @id @default(uuid())
  sectionKey String
  promptKind String
  version    Int
  content    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sectionKey, promptKind, version])
  @@index([sectionKey, promptKind, isActive])
  @@map("report_prompt_template")
}

model ReportGenerationRun {
  id                    String   @id @default(uuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id])
  symbol                String
  sectionKey            String
  promptTemplateVersion Int?
  inputPayloadJson      Json?
  outputPayloadJson     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId, sectionKey, createdAt])
  @@map("report_generation_run")
}

model ReportEnhancementRun {
  id                 String   @id @default(uuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id])
  symbol             String
  sectionKey         String
  sectionId          Int
  beforeText         String
  afterText          String?
  userInstruction    String
  promptContextJson  Json?
  model              String?
  providerResponseId String?
  citationsJson      Json?
  status             String
  errorMessage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId, sectionKey, createdAt])
  @@index([symbol, sectionKey])
  @@map("report_enhancement_run")
}
